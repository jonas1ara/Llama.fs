<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>LlamaFS</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Utils.fs" />
    <Compile Include="Tokenizer.fs" />
    <Compile Include="Model.fs" />
    <Compile Include="Llama.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FluentAssertions" Version="7.0.0-alpha.3" />
    <PackageReference Include="Microsoft.ML.Tokenizers" Version="0.21.1" />
    <PackageReference Include="TorchSharp" Version="0.101.5" />
    <PackageReference Include="libtorch-cuda-12.1-win-x64" Version="2.1.0.1" />
    <PackageReference Include="TorchSharp.PyBridge" Version="1.2.0" />
  </ItemGroup>

</Project>
